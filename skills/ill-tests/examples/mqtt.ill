# mqtt_client reference: broker container + client, pub/sub, binary payloads
#
# only mqtt 5 is supported. subscribe_<qos> / publish_<qos> bake the qos into
# the command name. ~b and ~hex squiggles produce byte payloads.

actor broker = container,
  image: "eclipse-mosquitto"
  internal_port: 1883
  vars:
    @access read
    port: 1883
actor alice = mqtt_client

as broker:
  run,
    external_port: self.port

as alice:
  connect,
    host: "localhost"
    port: broker.port

  subscribe_0 "greetings"

  publish_0 "greetings", ~b`hello`
  receive publish
  assert ok.payload == ~b`hello`
  assert ok.topic == "greetings"

  # capture and interpolate into a payload
  publish_0 "greetings", ~b`world`
  receive publish
  let last_msg = ok.payload

  publish_0 "greetings", ~b`got: ${last_msg}`
  receive publish
  assert ok.payload == ~b`got: world`

  # binary payload via ~hex
  publish_0 "greetings", ~hex`DEADBEEF`
  receive publish
  assert ok.payload == ~hex`DEADBEEF`

  # negative: empty topic
  publish_0 "", ~b`bad topic`
  assert error.mqtt.reason == :invalid_topic

  # explicit timeout (default is 5 seconds)
  publish_0 "greetings", ~b`last message`
  receive publish, timeout: 2
  assert ok.payload == ~b`last message`

  disconnect,
    reason_code: 0
    user_properties:
      "reason": "test complete"
