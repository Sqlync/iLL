# multi-actor reference: full bring-up — db, api, signup over http, verify in sql
#
# shows the @mut once @access read pattern: alice captures her user_id from
# the signup response and bob reads it later when he queries the db.

actor db = container,
  image: "postgres:18"
  internal_port: 5432
  vars:
    @access read
    port: 12345
actor api = exec,
  command: "python3 manage.py runserver 8080"
actor alice = http_client,
  vars:
    @mut once
    @access read
    user_id
actor bob = pg_client

as db:
  @expect "The database needs to start before the REST server and bob's client"
  run,
    external_port: self.port
    env:
      POSTGRES_PASSWORD: "root"

as api:
  run,
    env:
      POSTGRES_PORT: db.port
      POSTGRES_PASSWORD: "root"

as alice:
  post "http://localhost:8080/signup",
    headers:
      "Content-Type": "application/json"
    body: ~json`{"name": "alice", "email": "alice@example.com"}`
  assert ok.status == 201
  let resp = parse ok.body as json
  self.user_id = resp["id"]

as bob:
  connect,
    user: "root"
    password: "root"
    port: db.port
    database: "test"

  @expect "Alice should be in the database, with correct name and email"
  query ~sql`SELECT name, email FROM users WHERE id = ${alice.user_id}`
  assert ok.row[0] == ["alice", "alice@example.com"]
