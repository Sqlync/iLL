# container reference: image and dockerfile forms, env, port mapping
#
# `image:` pulls a published image; `dockerfile:` builds locally. internal_port
# is the port the process listens on inside the container; external_port is
# what gets mapped on the host.

actor nginx = container,
  image: "nginx:latest"
  internal_port: 80
  vars:
    @access read
    port: 8080

as nginx:
  run,
    external_port: self.port
    env:
      NGINX_HOST: "localhost"

# dockerfile form — paths resolve relative to this .ill file
actor app = container,
  dockerfile: "languages/python.Dockerfile"
  internal_port: 8080
  vars:
    @access read
    port: 8081

as app:
  run,
    external_port: self.port

as app:
  stop
