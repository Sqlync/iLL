# http_client reference: verbs, headers, json parse, status assertions
#
# http_client has no connect — http is stateless. the api here is a container
# that exposes its port and base url for interpolation.

actor api = container,
  dockerfile: "./api.Dockerfile"
  internal_port: 8080
  vars:
    @access read
    port: 8080
    base: "http://localhost:8080"
actor alice = http_client

as api:
  run,
    external_port: self.port

as alice:
  # login, capture token
  post "${api.base}/auth/login",
    headers:
      "Content-Type": "application/json"
    body: ~json`{"username": "alice", "password": "secret"}`
  assert ok.status == 200
  let auth = parse ok.body as json
  let token = auth["token"]

  # use the token; assert on a response header
  get "${api.base}/profile",
    headers:
      "Authorization": "Bearer ${token}"
  assert ok.status == 200
  assert ok.headers["Content-Type"] == "application/json"

  # negative: missing auth surfaces as error.http.status
  get "${api.base}/profile"
  assert error.http.status == 401

  # transport-level failure (timeout) is on error.network, not error.http
  get "${api.base}/slow",
    timeout: 50
  assert error.network.reason == :timeout
